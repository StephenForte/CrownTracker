# Required for the web app. Use a long, random string in production.
APP_PASSWORD=change-me
SESSION_SECRET=replace-with-at-least-32-random-characters

# Render provides this automatically from the blueprint. Postgres.app's local default:
DATABASE_URL=postgresql://localhost:5432/crown_tracker

# Required by every market-research run.
TAVILY_API_KEY=

# Phase 1B is deliberately disabled until BOTH fields below are set. The monthly
# cap is counted in the database before every Tavily request, so an expanded run
# cannot silently exceed the allowance. It is a CREDIT cap (not dollars): at
# Tavily's current $0.008 PAYG rate, 1250 credits is about $10 before any free
# credits that the account may have. Advanced searches consume two credits.
TAVILY_MONTHLY_CREDIT_CAP=
ANTHROPIC_API_KEY=
# Optional override. Keep this provider-configurable rather than hard-coding it.
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
