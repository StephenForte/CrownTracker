# Required for the web app. Use a long, random string in production.
APP_PASSWORD=change-me
SESSION_SECRET=replace-with-at-least-32-random-characters

# Remote Claude/Cowork MCP connector. Disabled unless exactly "true". When
# enabled, also set MCP_PUBLIC_BASE_URL (canonical HTTPS URL, no trailing slash)
# and MCP_DATABASE_URL (least-privilege role from npm run mcp:provision-readonly).
# Authorization uses APP_PASSWORD on the consent screen; changing APP_PASSWORD
# does not revoke tokens — use the Connectors page. Never spends research credits.
MCP_REMOTE_ENABLED=false
MCP_PUBLIC_BASE_URL=
MCP_DATABASE_URL=
# Optional comma-separated browser origins beyond Claude's standard web
# origins. Server-to-server Claude calls normally omit the Origin header.
MCP_ALLOWED_ORIGINS=

# Render provides this automatically from the blueprint. Postgres.app's local default:
DATABASE_URL=postgresql://localhost:5432/crown_tracker

# Required by every market-research run.
TAVILY_API_KEY=

# Optional: on-demand WatchBase reference lookup for the add-watch form. This
# is a paid provider, so it remains disabled until both values are set. The
# cap is atomically counted in Postgres before each explicit lookup; start
# conservatively (for example, 10) and raise it intentionally.
WATCHBASE_API_KEY=
WATCHBASE_LOOKUP_MONTHLY_CREDIT_CAP=

# Phase 1B is deliberately disabled until this flag is exactly "true" AND BOTH
# provider settings below are set. Credentials alone never enable enrichment.
PHASE1B_ENRICHMENT_ENABLED=false

# The monthly cap is counted in the database before every Phase 1B Tavily
# request, so an expanded run cannot silently exceed the allowance. It is a
# CREDIT cap (not dollars): at Tavily's current $0.008 PAYG rate, 1250 credits
# is about $10 before any free credits that the account may have. Advanced
# searches consume two credits.
TAVILY_MONTHLY_CREDIT_CAP=
ANTHROPIC_API_KEY=
# Optional override. Keep this provider-configurable rather than hard-coding it.
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001

# Phase 3B email alerts are opt-in. Set all three values together after
# verifying your sender domain in Resend. Alerts cover saved price thresholds,
# stale research (48h+), and Tavily budget milestones (80% and 100%).
RESEND_API_KEY=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=
